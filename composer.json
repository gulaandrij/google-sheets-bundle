{
    "name": "gulaandrij/google-sheets-bundle",
    "type": "symfony-bundle",
    "description": "Symfony bundle exposing a higher-level Google Sheets service on top of revolution/laravel-google-sheets.",
    "keywords": [
        "symfony",
        "symfony-bundle",
        "google",
        "google-sheets",
        "sheets"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Andrij Gula",
            "email": "gyla.andrij@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "google/apiclient": "^2.16",
        "revolution/laravel-google-sheets": "^7.2",
        "symfony/config": "^6.4 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.0 || ^12.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/yaml": "^6.4 || ^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Gulaandrij\\GoogleSheetsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gulaandrij\\GoogleSheetsBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "lint:fix": "vendor/bin/php-cs-fixer fix",
        "stan": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
